# Server Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration
CORS_ORIGIN=*

# Health Check Configuration
HEALTH_CHECK_URL=http://localhost:3000/health

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# Database Configuration (Prisma)
DATABASE_URL="mysql://username:password@host:port/database"

# For Railway MySQL, use this format:
# DATABASE_URL="mysql://root:password@containers-us-west-XXX.railway.app:XXXX/railway"

# For local MySQL:
# DATABASE_URL="mysql://root:password@localhost:3306/todo_app"

# MySQL Database Configuration (alternative individual vars)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_NAME=todo_app

# Database Configuration (if needed)
# DATABASE_URL=your_database_url_here

# Logging Configuration
# LOG_LEVEL=info

# API Configuration
# API_BASE_URL=https://your-api-domain.com

# External Services (if needed)
# REDIS_URL=redis://localhost:6379
# EMAIL_SERVICE_API_KEY=your_email_service_key
